# Copy to .env and fill these values. Never commit the real .env.
# Read by main.py (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY),
# safenav.py (MAPBOX_ACCESS_TOKEN), and tasks/zone_generator.py.

# Supabase project REST URL, e.g. https://<project-ref>.supabase.co
# (or http://localhost:54321 when using the Supabase CLI locally).
SUPABASE_URL=

# Supabase SERVICE ROLE key (server-side only — bypasses RLS). Required.
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox token used for Directions API calls in safenav.py. Required.
MAPBOX_ACCESS_TOKEN=

# Sarvam AI subscription key (sk_...). Required for /ai/chat and /ai/deterrent.
# Read by services/sarvam_client.py.
SARVAM_API_KEY=

# Optional Sarvam tunables (sensible defaults applied if unset):
#   SARVAM_CHAT_MODEL  -> sarvam-30b (default, fast+consistent) | sarvam-105b
#                         (sarvam-m is deprecated and now rejected by the API)
#   SARVAM_TTS_SPEAKER -> a valid bulbul:v3 voice, e.g. vijay (default), ratan, ritu, priya
SARVAM_CHAT_MODEL=
SARVAM_TTS_SPEAKER=
