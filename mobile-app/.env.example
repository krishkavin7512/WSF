# Copy to .env and fill these values. Never commit the real .env.
# NOTE: pubspec.yaml bundles `.env` as a Flutter asset, so this file MUST exist
# (even if partially filled) for `flutter pub get` / build to succeed.
# Loaded in main.dart via flutter_dotenv.

# Mapbox PUBLIC access token (pk....). Used by main.dart (map) and
# mapbox_service.dart (geocoding/suggestions).
MAPBOX_ACCESS_TOKEN=

# Supabase project REST URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase ANON (public) key — safe to ship in a mobile client under RLS.
SUPABASE_ANON_KEY=

# Base URL of the FastAPI backend used by api_service.dart for /get-safe-route.
# Android emulator -> http://10.0.2.2:8000 ; iOS simulator/desktop -> http://localhost:8000
BACKEND_API_BASE_URL=
